{
  "openapi": "3.1.0",
  "info": {
    "title": "Factory Admin API",
    "version": "v1"
  },
  "paths": {
    "/v1/admin/factory": {
      "get": {
        "summary": "Factory pipeline status",
        "operationId": "getFactoryStatus",
        "responses": {
          "200": {
            "description": "Factory status"
          }
        }
      }
    },
    "/v1/admin/events": {
      "get": {
        "summary": "Query raw CloudEvents telemetry",
        "operationId": "getEvents",
        "responses": {
          "200": {
            "description": "Event list"
          }
        }
      }
    },
    "/v1/admin/agents": {
      "get": {
        "summary": "Agent quality and throughput",
        "operationId": "getAgentStatus",
        "responses": {
          "200": {
            "description": "Agent status"
          }
        }
      }
    },
    "/v1/admin/deployments": {
      "get": {
        "summary": "Recent deployments",
        "operationId": "getDeployments",
        "responses": {
          "200": {
            "description": "Deployment list"
          }
        }
      }
    },
    "/v1/admin/project-health": {
      "get": {
        "summary": "Derived project health from centralized events",
        "operationId": "getProjectHealth",
        "responses": {
          "200": {
            "description": "Project health"
          }
        }
      }
    },
    "/v1/admin/project/canary": {
      "post": {
        "summary": "Evaluate project canary from centralized events",
        "operationId": "runProjectCanary",
        "responses": {
          "200": {
            "description": "Canary result"
          }
        }
      }
    },
    "/v1/admin/project/scenarios/{scenarioId}/verify": {
      "post": {
        "summary": "Verify a scenario from centralized events",
        "operationId": "verifyScenario",
        "responses": {
          "200": {
            "description": "Scenario verification result"
          }
        }
      }
    },
    "/v1/admin/architecture/tasks": {
      "post": {
        "summary": "Queue an architecture task",
        "operationId": "enqueueArchitectureTask",
        "responses": {
          "200": {
            "description": "Queued architecture task"
          }
        }
      },
      "get": {
        "summary": "List architecture tasks",
        "operationId": "listArchitectureTasks",
        "responses": {
          "200": {
            "description": "Architecture task list"
          }
        }
      }
    },
    "/v1/admin/architecture/tasks/{taskId}": {
      "get": {
        "summary": "Get architecture task",
        "operationId": "getArchitectureTask",
        "responses": {
          "200": {
            "description": "Architecture task"
          }
        }
      }
    },
    "/v1/admin/architecture/tasks/{taskId}/cancel": {
      "post": {
        "summary": "Cancel architecture task",
        "operationId": "cancelArchitectureTask",
        "responses": {
          "200": {
            "description": "Canceled architecture task"
          }
        }
      }
    },
    "/v1/admin/architecture/tasks/{taskId}/retry": {
      "post": {
        "summary": "Retry architecture task",
        "operationId": "retryArchitectureTask",
        "responses": {
          "200": {
            "description": "Retried architecture task"
          }
        }
      }
    },
    "/v1/admin/architecture/runs/{runId}": {
      "get": {
        "summary": "Get architecture run",
        "operationId": "getArchitectureRun",
        "responses": {
          "200": {
            "description": "Architecture run"
          }
        }
      }
    },
    "/v1/admin/implementation/tasks": {
      "post": {
        "summary": "Queue an implementation task",
        "operationId": "enqueueImplementationTask",
        "responses": {
          "200": {
            "description": "Queued implementation task"
          }
        }
      },
      "get": {
        "summary": "List implementation tasks",
        "operationId": "listImplementationTasks",
        "responses": {
          "200": {
            "description": "Implementation task list"
          }
        }
      }
    },
    "/v1/admin/implementation/tasks/{taskId}": {
      "get": {
        "summary": "Get implementation task",
        "operationId": "getImplementationTask",
        "responses": {
          "200": {
            "description": "Implementation task"
          }
        }
      }
    },
    "/v1/admin/implementation/tasks/{taskId}/cancel": {
      "post": {
        "summary": "Cancel implementation task",
        "operationId": "cancelImplementationTask",
        "responses": {
          "200": {
            "description": "Canceled implementation task"
          }
        }
      }
    },
    "/v1/admin/implementation/tasks/{taskId}/retry": {
      "post": {
        "summary": "Retry implementation task",
        "operationId": "retryImplementationTask",
        "responses": {
          "200": {
            "description": "Retried implementation task"
          }
        }
      }
    },
    "/v1/admin/implementation/runs/{runId}": {
      "get": {
        "summary": "Get implementation run",
        "operationId": "getImplementationRun",
        "responses": {
          "200": {
            "description": "Implementation run"
          }
        }
      }
    },
    "/v1/events": {
      "post": {
        "summary": "Ingest CloudEvents telemetry",
        "operationId": "ingestEvent",
        "responses": {
          "202": {
            "description": "Event accepted"
          }
        }
      }
    }
  }
}
