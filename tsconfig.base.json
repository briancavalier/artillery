{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@darkfactory/contracts": ["packages/factory-contracts/src/index.ts"],
      "@darkfactory/core": ["packages/factory-core/src/index.ts"],
      "@darkfactory/runner": ["packages/factory-runner/src/index.ts"],
      "@darkfactory/implementation-provider-codex": ["packages/implementation-provider-codex/src/index.ts"],
      "@darkfactory/project-adapter-artillery": ["packages/project-adapter-artillery/src/index.ts"],
      "@artillery/game": ["apps/artillery-game/src/server/index.ts"]
    },
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]
  }
}
